# Rust build artifacts
/target/
editor/zed/target/

# Compiled TASM output (compiler-generated)
*.tasm

# Hand-written baselines are committed source
!baselines/**/*.tasm

# Neural/formal cache (generated by trident bench, ephemeral)
baselines/**/*.neural.tasm
baselines/**/*.formal.tasm

# Compiled WASM grammars
*.wasm

# Node.js
**/node_modules/

# Tree-sitter build
**/build/

# Tree-sitter grammar repos (managed separately)
editor/tree-sitter-trident/
editor/zed/grammars/

# Proof artifacts (generated by trisha prove / trident bench)
*.proof.toml

# OS
.DS_Store

# Trained model weights — too large for git (v2 checkpoint ~30MB)
model/

# Agent memory — keep plans/audits/other, ignore scratch
/.claude/scratch/
